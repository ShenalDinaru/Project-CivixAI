PORT=5000
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/

EMAIL_USER=your_email_username
EMAIL_PASSWORD=your_email_password

FRONTEND_URL=http://localhost:5000
CHATBOT_SCANNER_URL=http://localhost:3000

# IMPORTANT:
# Use one stable secret value in ALL environments.
# If this changes, previously encrypted vault records cannot be decrypted.
VAULT_ENCRYPTION_KEY=replace_with_generated_key

